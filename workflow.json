    {
      "parameters": {
        "jsCode": "const jobs = $input.all();\n\nconst relevant = jobs.filter(item => {\n  const tags = item.json.tags || [];\n  const position = (item.json.position || '').toLowerCase();\n  \n  const keywords = ['ai', 'automation', 'python', 'n8n', 'machine learning',\n                    'backend', 'developer', 'engineer'];\n  \n  const excluded = ['senior', 'lead', 'manager', 'director', \n                    'head', 'principal', 'staff', 'vp', 'chief'];\n  \n  const isRelevant = keywords.some(k =>\n    position.includes(k) || tags.some(t => t.toLowerCase().includes(k))\n  );\n  \n  const isTooSenior = excluded.some(e => position.includes(e));\n  \n  return isRelevant && !isTooSenior;\n});\n\nreturn relevant.slice(0, 5).map(item => ({\n  json: {\n    position: item.json.position,\n    company: item.json.company,\n    tags: item.json.tags,\n    url: `https://remoteok.com/remote-jobs/${item.json.slug}`\n  }\n}));"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -16,
        -32
      ],
      "id": "59cdf071-75d3-45f1-bf92-536a334337b6",
      "name": "Code in JavaScript"
    },
    {
